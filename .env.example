# Database
DATABASE_URL="postgresql://sfadmin:sfpassword@localhost:5432/school_finance"
POSTGRES_USER=sfadmin
POSTGRES_PASSWORD=sfpassword
POSTGRES_DB=school_finance

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_REFRESH_SECRET=change-this-to-another-long-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# App
APP_NAME="School Finance Manager"
BASE_CURRENCY=USD
